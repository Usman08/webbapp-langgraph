# =============================================================================
# LangGraph WebApp — .gitignore
# Python backend + Node/React frontend + LangGraph/LangChain
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & Environment
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials.json

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# Type checking
.mypy_cache/
.dmypy.json
.pytype/
pyrightconfig.json

# Jupyter
.ipynb_checkpoints/
*.ipynb

# LangChain / LangGraph runtime artifacts
langchain_cache/
langgraph_cache/
*.vectorstore
chroma_db/
faiss_index/

# -----------------------------------------------------------------------------
# Node / JavaScript / TypeScript
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Build output
dist/
out/
.next/
.nuxt/
.svelte-kit/
.output/

# Caches
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
.prettiercache

# Testing
coverage/
.nyc_output/
playwright-report/
test-results/

# Misc
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# Logs & Debugging
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# OS & Editor
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains
.idea/
*.iml
*.iws

# Vim / Emacs
*.swp
*.swo
*~
\#*\#

# -----------------------------------------------------------------------------
# Docker & Infrastructure
# -----------------------------------------------------------------------------
.docker/
docker-compose.override.yml

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
