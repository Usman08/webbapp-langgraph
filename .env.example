# Groq API
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-120b

# Internal shared secret between .NET backend and AI engine
ENGINE_TOKEN=change_me_to_a_random_secret

# PostgreSQL
POSTGRES_DB=salesinvoice
POSTGRES_USER=salesinvoice
POSTGRES_PASSWORD=salesinvoice

# Frontend API URL (for local dev without Docker)
VITE_API_URL=http://localhost:8080
